# Корневой контекст используется backend, gns3-service и gns3-mcp образами
# (нужны backend/, mcp-sdk/, gns3/gns3-service/, gns3/gns3-mcp/).
# Остальное в образ не идёт, чтобы не гонять 1.8G в docker daemon.
**/node_modules
**/__pycache__
**/.pytest_cache
**/.ruff_cache
**/.next
**/.next-docs
.git
frontend
gns3
!gns3/gns3-service
!gns3/gns3-mcp
autotests
deployment
docs
.claude
.archive
.evidence
**/.superpowers
**/.venv
*.log
**/.DS_Store
**/*.png
**/*.webp
