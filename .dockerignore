**/node_modules
**/__pycache__
**/.pytest_cache
**/.ruff_cache
**/.next
**/.next-docs
.git
frontend
gns3
autotests
deployment
docs
.claude
.archive
.evidence
**/.superpowers
**/.venv
*.log
**/.DS_Store
**/*.png
**/*.webp
