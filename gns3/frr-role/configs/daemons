zebra=yes
# OSPF не нужен: единственная активная роль GW маршрутизирует два /24 через
# connected-маршруты zebra. Вернуть ospfd=yes при возврате OSPF-лаб (роли R1/R2).
ospfd=no
ospf6d=no
ripd=no
ripngd=no
isisd=no
pimd=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vtysh_enable=yes
zebra_options="  --daemon -A 127.0.0.1 -s 90000000"
ospfd_options="  --daemon -A 127.0.0.1"
