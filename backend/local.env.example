# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=onlinetlabs
# DB_SQL_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# API
ENVIRONMENT=development
# DEBUG=false
# API_PORT=8000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=change-me-in-production

# Agents / LLM
AGENTS_PROVIDER=anthropic
AGENTS_MODEL=claude-sonnet-4-20250514
AGENTS_API_KEY=sk-ant-your-key-here
# AGENTS_BASE_URL=
# AGENTS_TEMPERATURE=0.3
# AGENTS_MAX_TOKENS=4096
# AGENTS_REQUEST_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Config file (optional, defaults to os.environ)
# ENV_FILE=local.env
# CONFIG_PASSWORD=  # required if ENV_FILE ends with .aes
