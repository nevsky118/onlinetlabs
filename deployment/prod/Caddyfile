# Caddy: реверс-прокси + автоматический TLS (Let's Encrypt).
# Cloudflare-прокси отключён (DNS only) → домен резолвится прямо на сервер,
# Caddy сам берёт публично-доверенный серт по ACME (порты 80/443 открыты).
# Домен — из env APP_DOMAIN (в репо не хранится). ACME-email не задаём
# (необязателен; при желании — через env, чтобы не светить в репо).

{$APP_DOMAIN}, www.{$APP_DOMAIN} {
	# Let's Encrypt — автоматически (proxy off, домен указывает на сервер).
	# Прежний Cloudflare Origin Certificate (для режима proxied / SSL Full strict)
	# оставлен закомментированным — вернуть при включении прокси Cloudflare:
	# tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin-key.pem

	# WebSocket-эндпоинты сессии → backend (wss://<домен>/ws/...)
	@ws path /ws/*
	reverse_proxy @ws backend:8000

	# GNS3 Web UI студента: SPA + ассеты (/static/web-ui/*) и API/websockets (/v3/*)
	# → gns3-server. Без этого ссылка auth-relay упирается в Next.js 404.
	@gns3 path /static/web-ui/* /v3/*
	reverse_proxy @gns3 gns3-server:3080

	# Всё остальное → Next.js фронт (он сам проксирует /api/* на backend внутри сети)
	reverse_proxy frontend:3000

	encode gzip zstd
}
